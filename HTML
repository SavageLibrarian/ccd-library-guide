<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CCD Library | Finding Information</title>
  <script src="https://unpkg.com/vue@3"></script>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div id="app">
  <div class="container">
    
    <aside class="sidebar">
      <h2>CCD Library</h2>
      <ul>
        <li v-for="section in sections" 
            :key="section.id"
            @click="navigate(section.id)">
          {{ section.title }}
        </li>
      </ul>
    </aside>

    <main class="content">
      <h1>{{ current.title }}</h1>
      <p v-for="para in current.content">{{ para }}</p>
    </main>

  </div>
</div>

<script src="app.js"></script>
</body>
</html>
